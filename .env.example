# ========== Database ==========
DATABASE_URL=postgresql+asyncpg://abp_user:abp_password@localhost:5432/agent_base_platform
DATABASE_URL_SYNC=postgresql://abp_user:abp_password@localhost:5432/agent_base_platform

# ========== Redis ==========
REDIS_URL=redis://localhost:6380/0

# ========== JWT ==========
JWT_SECRET_KEY=change-me-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== Application ==========
APP_NAME=AgentBasePlatform
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# ========== LLM (optional for MVP) ==========
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# DEFAULT_MODEL_NAME=deepseek-chat
